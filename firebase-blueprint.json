{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "E-commerce product details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "stock": { "type": "number" },
        "isFeatured": { "type": "boolean" },
        "discount": { "type": "number" }
      },
      "required": ["name", "price", "category", "image"]
    },
    "Cart": {
      "title": "Cart",
      "description": "User shopping cart",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "quantity": { "type": "number" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "address": { "type": "object" },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Review": {
      "title": "Review",
      "description": "Product review and rating",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "isModerated": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating", "comment"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "/carts/{userId}": {
      "schema": "Cart",
      "description": "User shopping carts"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "/wishlists/{userId}": {
      "schema": "object",
      "description": "User wishlists"
    }
  }
}
